flowchart TB
    subgraph ExternalData["外部数据源"]
        RSS[RSS源<br/>道琼斯/彭博/MW]
        Sina[新浪财经<br/>行情/新闻/分钟线]
        Eastmoney[东方财富<br/>快讯/个股新闻]
        Tushare[Tushare<br/>股票基础信息/财务]
        WeChat[微信群聊<br/>监控数据]
        AKShare[AKShare<br/>宏观/汇率/资金流]
    end

    subgraph DataCollection["数据采集层 (定时任务)"]
        fetch_news["fetch_news_rss.py<br/>国际新闻<br/>每5分钟"]
        fetch_cn["fetch_cn_news_*.py<br/>国内新闻<br/>每2分钟"]
        fetch_minline["fetch_sina_minline_all_listed.py<br/>分钟线<br/>每日7:45"]
        fetch_stock["fetch_stock_news_*.py<br/>个股新闻"]
        fetch_chat["fetch_monitored_chatlogs_once.py<br/>群聊消息<br/>每3分钟"]
        backfill_macro["backfill_macro_series_akshare.py<br/>宏观数据"]
    end

    subgraph DataStorage["数据存储层"]
        PG[(PostgreSQL<br/>主业务库)]
        Redis[(Redis<br/>缓存/消息队列)]
    end

    subgraph LLMAnalysis["LLM智能分析层"]
        score_news["llm_score_news.py<br/>新闻重要性评分"]
        score_stock_news["llm_score_stock_news.py<br/>个股新闻评分<br/>6并发批处理"]
        score_sentiment["llm_score_sentiment.py<br/>情绪分析<br/>偏多/中性/偏空"]
        analyze_chat["llm_analyze_chatroom_investment_bias.py<br/>群聊投资倾向"]
        trend_analysis["llm_analyze_stock_trend.py<br/>趋势分析"]
        multi_role["llm_multi_role_company_review.py<br/>多角色研究"]
    end

    subgraph SignalBuilder["信号构建层"]
        build_signal["build_investment_signal_tracker.py<br/>投资信号聚合"]
        build_theme["build_theme_hotspot_engine.py<br/>主题热点追踪"]
        build_candidate["build_chatroom_candidate_pool.py<br/>候选池生成"]
        build_state["build_signal_state_machine.py<br/>信号状态机"]
    end

    subgraph TaskScheduler["任务调度层"]
        cron[Linux Cron<br/>定时触发]
        registry[job_registry.py<br/>任务定义]
        orchestrator[job_orchestrator.py<br/>任务编排]
    end

    subgraph APILayer["API服务层"]
        backend["backend/server.py<br/>Monolithic API<br/>Port: 8002"]
    end

    subgraph Frontend["前端展示层"]
        web_new["Vue3 + TypeScript<br/>Port: 5173"]
        web_old["HTML/JS<br/>Port: 8080"]
        nginx["Nginx<br/>反向代理 Port: 8077"]
    end

    subgraph Realtime["实时推送层"]
        ws["ws_realtime_server.py<br/>WebSocket Port: 8010"]
        stream_worker["stream_news_worker.py<br/>消息消费者"]
    end

